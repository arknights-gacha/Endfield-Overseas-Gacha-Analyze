                                </div>
                                <div class="ORrqqm">
                                    <div class="qcP3VO">
                                    <% if (item.isNew) { %>
                                        <div class="QnXVrG">NEW</div>
                                    <% } %>
                                    <% 
                                       let sc = starClasses[item.rarity] || 'UN5Fou'; 
