        <!-- 近期出金（可折疊，預設展開） -->
        <div class="HgfD8Q">
          <div class="tshJ_L">近期出金 ▲</div>
          <div class="collapsible-content open">
            <div class="KXADwl">
              <div class="Ysu7ON"></div>
              <span></span><span></span>
            </div>
              <div style="display: flex; justify-content: flex-start; margin-bottom: 0.5rem; padding-left: 13.5rem;">
                 <span style="font-size: 0.9rem; color: #10d1fe; cursor: pointer; user-select: none; font-weight: bold;" onclick="toggleAllGroups('recent')">[ 全部摺疊 / 展開 ]</span>
              </div>
              <div class="mzlLY0">
                <div class="pvfQQe">
                  <div class="_P1qVa">獲得幹員（抽數）</div>
                  <div class="Zs7Y7r">尋訪卡池</div>
                  <div class="GETong">尋訪時間</div>
                </div>
                <div class="EkxzYd" id="recent-container">
                <% const golds = logs.filter(item => (item.rarity === 6)); %>
