                      </div>
                    </div>
                    <% }) %>
                <% } %>
              </div>
            </div>
          </div>
        </div>

        <!-- 尋訪記錄：顯示所有角色（可折疊，預設展開） -->
        <div class="HgfD8Q">
          <div class="tshJ_L">紀錄明細 ▲</div>
          <div class="collapsible-content open">
            <div class="KXADwl">
              <div class="Ysu7ON"></div>
              <span></span><span></span>
            </div>
            <div style="display: flex; justify-content: flex-start; margin-bottom: 0.5rem; padding-left: 13.5rem;">
               <span style="font-size: 0.9rem; color: #f7ff00; cursor: pointer; user-select: none; font-weight: bold;" onclick="toggleAllGroups('history')">[ 全部摺疊 / 展開 ]</span>
            </div>
            <div class="mzlLY0">
              <div class="pvfQQe">
                <div class="_P1qVa">獲得項目</div>
                <div class="Zs7Y7r">所屬卡池</div>
                <div class="GETong">獲取時間</div>
              </div>
              <div class="EkxzYd" id="history-container">
                <% 
                  let groupsMap = new Map();
                  logs.forEach(item => {
                      let currentPoolName = item.poolName || `${item.poolId}（名稱未顯示）`;
                      let currentPoolId = item.poolId;
                      if (!groupsMap.has(currentPoolId)) {
                          groupsMap.set(currentPoolId, { poolName: currentPoolName, poolId: currentPoolId, category: item.poolCategory, items: [] });
                      }
                      groupsMap.get(currentPoolId).items.push(item);
                  });
                  let allGroups = Array.from(groupsMap.values());
                  
                  allGroups.forEach(function(group) { 
                    let pStats = stats.starcountsPool[group.poolId] || { '6':0, '5': 0, '4': 0, '3': 0, '2': 0 };
                    let pTotal = pStats['6'] + pStats['5'] + pStats['4'] + pStats['3'] + pStats['2'];
                %>
                <div class="pool-group-wrapper" data-pool="<%= group.poolId %>" data-recordcat="<%= group.category %>">
                  <div class="tshJ_L" style="background: rgba(255,255,255,0.05); margin: 6px 0 2px 0; height: 2rem; padding: 4px 15px; font-size: 1rem; line-height: 1.5; color: #f7ff00; border-radius: 4px; border-left: 4px solid #f7ff00;"><%= group.poolName %>（<%= pTotal %>抽） ▲</div>
                  <div class="collapsible-content open" style="margin-bottom: 0.5rem;">
                    <% group.items.forEach(function(item) { 
                      let sc = starClasses[item.rarity] || 'spIT3K';
                    %>
                  <div class="gX_vOH">
                    <div class="oX8Bos">
                      <div class="h1yWiG"><%= item.charName %></div>
                      <div class="feiJCc"><%= item.time %></div>
                    </div>
                    <div class="ORrqqm">
