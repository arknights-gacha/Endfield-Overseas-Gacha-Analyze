                if (!uniquePoolsMap.has(log.poolId)) {
                  uniquePoolsMap.set(log.poolId, { pName, category: log.poolCategory });
                }
              });
              let uniquePools = Array.from(uniquePoolsMap.entries());
              uniquePools.forEach(([pId, param], i) => { 
            %>
