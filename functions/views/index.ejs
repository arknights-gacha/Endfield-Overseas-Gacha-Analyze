            <% const categoriesArr = ['基礎尋訪', '特許尋訪', '啟程尋訪', '武庫申領']; %>
            <% categoriesArr.forEach(function(cat) { 
                 const costPerPull = (cat === '武庫申領') ? 198 : 500;
                 const currencyName = (cat === '武庫申領') ? '武庫配額' : '嵌晶玉';
                 
                 // Get total counts for this category
                 let cStats = stats.starcounts[cat] || { '6':0, '5': 0, '4': 0, '3': 0, '2': 0 };
                 let cTotal = cStats['6'] + cStats['5'] + cStats['4'] + cStats['3'] + cStats['2'];
                 let cCost = cTotal * costPerPull;
                 
                 // Avg pulls for gold (6-star for char, 5-star for weapon)
                 let goldCount = cStats['6'];
                 let avgPulls = goldCount > 0 ? (cTotal / goldCount).toFixed(2) : 0;
                 let avgCost = goldCount > 0 ? (cCost / goldCount).toFixed(2) : 0;
                 
                 // Latest pull logic for this category
                 // We find the first log that belongs to this category.
                 let catLogs = logs.filter(l => l.poolCategory === cat);
                 let lastLog = catLogs[0] || {};
                 let cLastPullName = lastLog.poolName || "無紀錄";
                 let cLastPullId = lastLog.poolId || "none";
                 let cAccumulation = stats.countAcc[cLastPullId] || 0;
                 
                 let lpStats = stats.starcountsPool[cLastPullId] || { '6':0, '5':0, '4':0, '3':0, '2':0 };
                 let lpTotal = lpStats['6'] + lpStats['5'] + lpStats['4'] + lpStats['3'] + lpStats['2'];
            %>
            <div class="dashboard-panel dashboard-cat-view" data-catview="<%= cat %>" style="display: none;">
                <div class="dashboard-card">
                    <h3>當前卡池狀態（<%= cat %>）</h3>
