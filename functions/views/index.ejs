                      let recentGroupsMap = new Map();
                      golds.forEach(item => {
                          let currentPoolName = item.poolName || `${item.poolId}（名稱未顯示）`;
                          let currentPoolId = item.poolId;
                          if (!recentGroupsMap.has(currentPoolId)) {
