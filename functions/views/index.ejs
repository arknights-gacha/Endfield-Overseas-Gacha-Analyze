  <script>
    // ======= Category Switching functionality =======
    let activeCategory = '基礎尋訪';

    function updateCategoryView() {
        // 1. Update Buttons
        document.querySelectorAll('.cat-btn').forEach(btn => {
            if (btn.getAttribute('data-cat') === activeCategory) {
                btn.classList.add('active');
            } else {
                btn.classList.remove('active');
            }
        });

        // 2. Update Checkboxes list rendering & checks
        document.querySelectorAll('.pool-filter-item').forEach(item => {
            if (item.getAttribute('data-poolcat') === activeCategory) {
                item.style.display = 'flex';
                // force check when switched
                item.querySelector('input').checked = true;
            } else {
                item.style.display = 'none';
                item.querySelector('input').checked = false;
            }
        });
        
        const toggleAll = document.getElementById('filter-pool-all');
        if (toggleAll) toggleAll.checked = true;

        // 3. Update Dashboard Panels
        document.querySelectorAll('.dashboard-cat-view').forEach(panel => {
            if (panel.getAttribute('data-catview') === activeCategory) {
                panel.style.display = 'flex';
            } else {
                panel.style.display = 'none';
            }
        });

        // 4. Update History Groups Render
        document.querySelectorAll('.pool-group-wrapper').forEach(wrapper => {
            if (wrapper.getAttribute('data-recordcat') === activeCategory) {
                wrapper.style.display = 'block';
            } else {
                wrapper.style.display = 'none';
            }
        });
        
        // 5. Update Recent Gold Render
        document.querySelectorAll('.recent-gold-item').forEach(wrapper => {
            if (wrapper.getAttribute('data-recordcat') === activeCategory) {
                wrapper.style.display = 'block';
            } else {
                wrapper.style.display = 'none';
            }
        });
    }

    document.querySelectorAll('.cat-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            activeCategory = this.getAttribute('data-cat');
            updateCategoryView();
        });
    });

    // Initialize display
    updateCategoryView();

    // ======= Standard Interactions =======

    // Mobile sidebar toggle
    const mobileBtn = document.querySelector('.uYZr59');
    const sidebar = document.querySelector('.CAmS7u');
    if (mobileBtn && sidebar) {
      mobileBtn.addEventListener('click', () => {
        mobileBtn.classList.toggle('OH5OMA');
        sidebar.classList.toggle('bWI6VY');
      });
    }

    // Accordion effect
    document.querySelectorAll(".tshJ_L").forEach((header) => {
      header.addEventListener("click", () => {
        const content = header.nextElementSibling;
        if (content && content.classList.contains('collapsible-content')) {
          content.classList.toggle("open");
          header.innerHTML = header.innerHTML.endsWith("▼")
            ? header.innerHTML.replace("▼", "▲")
            : header.innerHTML.replace("▲", "▼");
        }
      });
    });

    // Toggle all groups
    function toggleAllGroups(type) {
      const container = document.getElementById(type + '-container');
      if (!container) return;
      
      const headers = container.querySelectorAll('.pool-group-wrapper > .tshJ_L');
      let anyOpen = false;
      
      headers.forEach(h => {
        const content = h.nextElementSibling;
        // only check visible items
        if (h.parentElement.style.display !== 'none' && content && content.classList.contains('open')) {
          anyOpen = true;
        }
      });
      
      headers.forEach(h => {
        const content = h.nextElementSibling;
        if (!content || h.parentElement.style.display === 'none') return;
        
        if (anyOpen) {
           // Close all
           if (content.classList.contains('open')) {
             content.classList.remove('open');
             h.innerHTML = h.innerHTML.replace('▲', '▼');
           }
        } else {
           // Open all
           if (!content.classList.contains('open')) {
             content.classList.add('open');
             h.innerHTML = h.innerHTML.replace('▼', '▲');
           }
        }
      });
    }

    // Checkbox filter functionality
    const cbs = document.querySelectorAll('.pool-filter-cb');
    const toggleAll = document.getElementById('filter-pool-all');

    if (toggleAll) {
      toggleAll.addEventListener('change', function() {
        const show = this.checked;
        cbs.forEach(cb => {
          // only impact visible items
          if (cb.closest('.pool-filter-item').style.display !== 'none') {
            if (cb.checked !== show) {
              cb.checked = show;
              cb.dispatchEvent(new Event('change'));
            }
          }
        });
      });
    }

    cbs.forEach(cb => {
      cb.addEventListener('change', function() {
        // filter history groups based on checkbox selection
        // Since history has same logic (data-pool), we can hide those
        const poolName = this.value;
        const show = this.checked;
        
        if (toggleAll) {
          const visibleCbs = Array.from(cbs).filter(c => c.closest('.pool-filter-item').style.display !== 'none');
          const allChecked = visibleCbs.every(c => c.checked);
          const someChecked = visibleCbs.some(c => c.checked);
          toggleAll.checked = allChecked;
          toggleAll.indeterminate = someChecked && !allChecked;
        }

        document.querySelectorAll(`.pool-group-wrapper[data-pool="${poolName}"]`).forEach(wrapper => {
          // only apply logic if it belongs to current active category
          if (wrapper.getAttribute('data-recordcat') === activeCategory) {
              wrapper.style.display = show ? 'block' : 'none';
          }
        });
      });
    });
  </script>
</body>
</html>
