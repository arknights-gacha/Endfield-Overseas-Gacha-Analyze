                      <div class="tshJ_L" style="background: rgba(255,255,255,0.05); margin: 6px 0 2px 0; height: 2rem; padding: 4px 15px; font-size: 1rem; line-height: 1.5; color: #f7ff00; border-radius: 4px; border-left: 4px solid #f7ff00;"><%= group.poolName %>（<%= pTotal %>抽） ▲</div>
                      <div class="collapsible-content open" style="margin-bottom: 0.5rem;">
                        <% group.items.forEach(item => { %>
                            <div class="gX_vOH">
                                <div class="oX8Bos">
                                    <div class="h1yWiG"><%= item.charName %></div>
