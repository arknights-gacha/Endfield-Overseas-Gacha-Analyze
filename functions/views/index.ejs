            <a href="/logout" style="display: block; width: 100%; padding: 0.8rem; text-align: center; background: rgba(27,209,254,0.2); color: #1bd1fe; text-decoration: none; border-radius: 4px; font-weight: bold; transition: background 0.3s;" onmouseover="this.style.background='rgba(27,209,254,0.3)'" onmouseout="this.style.background='rgba(27,209,254,0.2)'">登出</a>
