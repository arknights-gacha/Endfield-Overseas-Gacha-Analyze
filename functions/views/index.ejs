                          }
                          recentGroupsMap.get(currentPoolId).items.push(item);
                      });
                      let recentGroups = Array.from(recentGroupsMap.values());
                    %>
                    <% recentGroups.forEach(group => { 
                        let pStats = stats.starcountsPool[group.poolId] || { '6':0, '5': 0, '4': 0, '3': 0, '2': 0 };
                        let pTotal = pStats['6'] + pStats['5'] + pStats['4'] + pStats['3'] + pStats['2'];
                    %>
