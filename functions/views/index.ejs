<!DOCTYPE html>
<html lang="zh-Hant">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0" />
    <meta http-equiv="pragma" content="no-cache">
    <meta http-equiv="cache-control" content="no-cache">
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <title>終末地 尋訪紀錄</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="stylesheet" href="/css/your.css" />
    <style>
      .collapsible-content {
        display: none;
      }
      .collapsible-content.open {
        display: block;
      }
      .tshJ_L {
        cursor: pointer;
      }
      /* Dashboard styles */
      .dashboard-panel {
        display: flex;
        flex-wrap: wrap;
        gap: 1.5rem;
        padding: 1.5rem;
        background: #121212;
        border-radius: 0.5rem;
        margin: 1rem;
        color: #fff;
        font-family: 'cwTeXHeiBold', 'Heiti TC', sans-serif;
      }
      .dashboard-card {
        flex: 1;
        min-width: 300px;
        padding: 1.5rem;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 0.5rem;
        border: 1px solid rgba(255, 255, 255, 0.1);
      }
      .dashboard-card h3 {
        margin-top: 0;
        color: #10d1fe;
        font-size: 1.25rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.2);
        padding-bottom: 0.5rem;
      }
      .dashboard-card p {
        font-size: 1.1rem;
        line-height: 1.6;
        margin: 0.8rem 0;
      }
      .dashboard-card .highlight-number {
        font-size: 1.3rem;
        color: #f7ff00;
        font-weight: bold;
      }
      
      .cat-btn {
        width: 100%;
        padding: 0.8rem;
        text-align: center;
        background: rgba(255,255,255,0.05);
        color: #ccc;
        border: 1px solid #333;
        border-radius: 4px;
        font-weight: bold;
        cursor: pointer;
        transition: all 0.3s;
      }
      .cat-btn.active {
        background: rgba(27,209,254,0.2);
        color: #1bd1fe;
        border-color: #1bd1fe;
      }
      .cat-btn:hover:not(.active) {
        background: rgba(255,255,255,0.1);
        color: #fff;
      }
      .recent-gold-item {
        display: flex;
      }
    </style>
  </head>
  <body class="dark-mode" style="background-color: #000000; color: #e0e0e0">
    
    <div class="n9kTOc">
      <div class="zpp1t9">
        <div class="uUPDec">
          <div class="Uqsjld">
            <div class="MvFHTi">
