        <form method="post" action="/login">
          <input type="hidden" name="method" value="selectRole" />
          <input type="hidden" name="oauthToken" value="<%= oauthToken %>" />
          <% roles.forEach(function(role, idx) { %>
            <div style="margin-bottom: 1rem; padding: 1rem; border: 1px solid #1bd1fe; border-radius: 0.25rem; cursor: pointer;">
                <label style="display: flex; align-items: center; cursor: pointer; width: 100%;">
