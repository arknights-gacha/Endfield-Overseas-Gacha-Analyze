    <!-- 等待遮罩 -->
    <div id="loadingOverlay" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.8); color: #fff; font-size: 1.5rem; text-align: center; line-height: 100vh; z-index: 1000;">
