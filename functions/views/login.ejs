    </div>

    <script>
      const cookieForm = document.getElementById("cookieForm");
      if (cookieForm) {
          cookieForm.addEventListener("submit", function () {
            document.getElementById("loadingOverlay").style.display = "block";
          });
      }

      const startFetchBtn = document.getElementById("startFetchBtn");
      if (startFetchBtn) {
          startFetchBtn.closest("form").addEventListener("submit", function () {
            document.getElementById("loadingOverlay").style.display = "block";
          });
      }

      const uploadForm = document.getElementById("uploadForm");
      if (uploadForm) {
        uploadForm.addEventListener("submit", async function(e) {
            e.preventDefault();
            document.getElementById("loadingOverlay").style.display = "block";
            
            const uid = document.getElementById("uploadUid").value;
            const fileInput = document.getElementById("uploadFile");
            
            if (!fileInput.files || fileInput.files.length === 0) {
                alert("請選擇檔案");
                document.getElementById("loadingOverlay").style.display = "none";
                return;
            }
            
            const file = fileInput.files[0];
            const reader = new FileReader();
            reader.onload = async function(evt) {
                try {
                    const logs = JSON.parse(evt.target.result);
                    const res = await fetch('/login', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ method: 'upload', uid: uid, logs: logs })
                    });
                    
                    if (res.redirected) {
                        window.location.href = res.url;
                    } else if (res.ok) {
                        window.location.href = '/';
                    } else {
                        const errorText = await res.text();
                        alert("上傳失敗: " + errorText);
                        document.getElementById("loadingOverlay").style.display = "none";
                    }
                } catch (err) {
                    alert("讀取檔案失敗或格式不正確: " + err.message);
                    console.error(err);
                    document.getElementById("loadingOverlay").style.display = "none";
                }
            };
            reader.readAsText(file);
        });
      }
    </script>

